[Unit]
Description=AI Partner Island family game server
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/aidi/ai-partner-island/ai-partner-island-server
Environment=HOST=0.0.0.0
Environment=PORT=8787
EnvironmentFile=-/home/aidi/ai-partner-island/ai-partner-island-server/.env
ExecStart=/usr/bin/npm start
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
